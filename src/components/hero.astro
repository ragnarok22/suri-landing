---
import { Download, ChevronRight, Check } from 'lucide-react'
import { Image } from 'astro:assets'
---

<header
  id="hero"
  class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden"
>
  <!-- Abstract Background Blobs -->
  <div
    aria-hidden="true"
    class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[800px] h-[800px] bg-emerald-100/40 dark:bg-emerald-900/20 rounded-full blur-3xl opacity-50 -z-10 animate-pulse-slow"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[600px] h-[600px] bg-yellow-100/40 dark:bg-yellow-900/20 rounded-full blur-3xl opacity-50 -z-10"
  >
  </div>

  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center gap-16">
      <!-- Text Content -->
      <div class="md:w-1/2 space-y-8 text-center md:text-left">
        <div
          class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300 rounded-full text-sm font-semibold mb-2 border border-emerald-100 dark:border-emerald-700"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
            ></span>
          </span>
          The #1 Mobile Manager in Suriname
        </div>

        <h1
          class="text-5xl lg:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.1] text-balance"
        >
          Master your <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-green-500"
          >
            Mobile Life
          </span>
        </h1>

        <p
          class="text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto md:mx-0 leading-relaxed"
        >
          Check your balance, top up instantly, and manage data plans with the
          app built for Suriname. Fast, secure, and easy.
        </p>

        <div
          class="flex flex-col sm:flex-row items-center justify-center md:justify-start gap-4"
        >
          <a
            href="#download"
            id="hero_download"
            class="w-full sm:w-auto px-8 py-4 bg-slate-900 text-white dark:bg-emerald-600 dark:hover:bg-emerald-500 rounded-xl font-bold flex items-center justify-center gap-3 hover:bg-emerald-700 transition-[background-color,box-shadow,transform] hover:shadow-xl hover:shadow-emerald-900/10 hover:-translate-y-1 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-900"
          >
            <Download
              className="w-5 h-5 group-hover:animate-bounce"
              aria-hidden="true"
            />
            <span>Download APK</span>
          </a>
          <a
            href="#features"
            id="hero_view_features"
            class="w-full sm:w-auto px-8 py-4 bg-white text-slate-700 dark:bg-slate-800 dark:text-slate-200 border border-slate-200 dark:border-slate-600 rounded-xl font-bold flex items-center justify-center gap-3 hover:bg-slate-50 dark:hover:bg-slate-700 transition-[background-color,border-color] hover:border-slate-300 dark:hover:border-slate-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-900"
          >
            <span>View Features</span>
            <ChevronRight className="w-4 h-4" aria-hidden="true" />
          </a>
        </div>

        <div
          class="pt-4 flex items-center justify-center md:justify-start gap-6 text-slate-400 text-sm font-medium"
        >
          <span class="flex items-center gap-2"
            ><Check className="w-4 h-4 text-emerald-500" aria-hidden="true" /> Supports
            Telesur</span
          >
          <span class="flex items-center gap-2"
            ><Check className="w-4 h-4 text-emerald-500" aria-hidden="true" /> Data
            Management</span
          >
        </div>
      </div>

      <!-- Hero Visual / App Screenshot -->
      <div class="hidden md:flex md:w-1/2 justify-center relative">
        <!-- Decorative elements behind phone -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[700px] bg-gradient-to-tr from-emerald-500/20 to-yellow-400/20 dark:from-emerald-500/10 dark:to-yellow-400/10 rounded-[3rem] -rotate-6 blur-xl"
        >
        </div>

        <!-- Phone Screenshot -->
        <div class="relative animate-float">
          <Image
            src="/screenshot1.png"
            alt="Suri App Screenshot"
            width={300}
            height={650}
            loading="eager"
            class="relative rounded-[2.5rem] shadow-2xl"
          />
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { trackEvent, trackSectionVisibility } from '@/lib/analytics'

  document.querySelector('#hero_download')?.addEventListener('click', () => {
    trackEvent('cta_click', { type: 'download', location: 'hero' })
  })

  document
    .querySelector('#hero_view_features')
    ?.addEventListener('click', () => {
      trackEvent('cta_click', { type: 'view_features', location: 'hero' })
    })

  trackSectionVisibility('#hero', 'hero')
</script>
