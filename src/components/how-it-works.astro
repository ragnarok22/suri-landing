---
import { Download } from 'lucide-react'
---

<section
  id="how-it-works"
  class="py-24 bg-emerald-950 dark:bg-slate-800 text-white dark:text-slate-100 overflow-hidden relative"
>
  <div
    aria-hidden="true"
    class="absolute top-0 left-0 w-full h-full opacity-10 dark:opacity-5"
    style="background-image: radial-gradient(#10b981 1px, transparent 1px); background-size: 32px 32px;"
  >
  </div>
  <div
    aria-hidden="true"
    class="hidden dark:block absolute top-0 left-0 w-full h-full opacity-5"
    style="background-image: radial-gradient(#64748b 1px, transparent 1px); background-size: 32px 32px;"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-16">
      <div class="md:w-1/2">
        <div
          class="inline-block px-3 py-1 bg-emerald-900 dark:bg-slate-700 rounded-full text-emerald-300 dark:text-emerald-400 text-xs font-bold mb-6 border border-emerald-800 dark:border-slate-600"
        >
          EASY SETUP
        </div>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-balance">
          Simple. Fast. Connected.
        </h2>
        <div class="space-y-8">
          <div class="flex gap-6 group">
            <div
              class="text-2xl font-bold text-emerald-500/50 group-hover:text-emerald-400 dark:text-emerald-400/50 dark:group-hover:text-emerald-300 transition-colors"
            >
              01
            </div>
            <div>
              <h3
                class="text-xl font-bold mb-2 group-hover:text-emerald-300 dark:group-hover:text-emerald-400 transition-colors"
              >
                Download Suri
              </h3>
              <p class="text-slate-400">
                Get the app directly from our website or app store.
              </p>
            </div>
          </div>
          <div class="flex gap-6 group">
            <div
              class="text-2xl font-bold text-emerald-500/50 group-hover:text-emerald-400 dark:text-emerald-400/50 dark:group-hover:text-emerald-300 transition-colors"
            >
              02
            </div>
            <div>
              <h3
                class="text-xl font-bold mb-2 group-hover:text-emerald-300 dark:group-hover:text-emerald-400 transition-colors"
              >
                Auto-Connect
              </h3>
              <p class="text-slate-400">
                We automatically detect your carrier and status.
              </p>
            </div>
          </div>
          <div class="flex gap-6 group">
            <div
              class="text-2xl font-bold text-emerald-500/50 group-hover:text-emerald-400 dark:text-emerald-400/50 dark:group-hover:text-emerald-300 transition-colors"
            >
              03
            </div>
            <div>
              <h3
                class="text-xl font-bold mb-2 group-hover:text-emerald-300 dark:group-hover:text-emerald-400 transition-colors"
              >
                Take Control
              </h3>
              <p class="text-slate-400">
                Top up, buy data, and track your usage immediately.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="md:w-1/2 flex justify-center">
        <div class="relative">
          <!-- Glow behind stats -->
          <div
            class="absolute inset-0 bg-emerald-500 blur-[100px] opacity-20 pointer-events-none"
          >
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div
              class="bg-white/5 backdrop-blur-md p-6 rounded-2xl border border-white/10 w-32 h-32 sm:w-40 sm:h-40 flex flex-col justify-center items-center transform translate-y-8 hover:bg-white/10 transition-colors"
            >
              <span class="text-4xl font-bold mb-2">10k+</span>
              <span class="text-xs text-emerald-200 dark:text-emerald-300"
                >Downloads</span
              >
            </div>
            <div
              class="bg-white/5 backdrop-blur-md p-6 rounded-2xl border border-white/10 w-32 h-32 sm:w-40 sm:h-40 flex flex-col justify-center items-center hover:bg-white/10 transition-colors"
            >
              <span class="text-4xl font-bold mb-2">4.8</span>
              <span class="text-xs text-emerald-200 dark:text-emerald-300"
                >User Rating</span
              >
            </div>
            <div
              class="bg-white/5 backdrop-blur-md p-6 rounded-2xl border border-white/10 w-32 h-32 sm:w-40 sm:h-40 flex flex-col justify-center items-center transform translate-y-8 hover:bg-white/10 transition-colors"
            >
              <span class="text-4xl font-bold mb-2">24/7</span>
              <span class="text-xs text-emerald-200 dark:text-emerald-300"
                >Availability</span
              >
            </div>
            <a
              id="how-it-works-download"
              href="#download"
              class="bg-emerald-600 dark:bg-emerald-700 p-6 rounded-2xl w-32 h-32 sm:w-40 sm:h-40 flex flex-col justify-center items-center shadow-lg shadow-emerald-500/30 hover:bg-emerald-500 dark:hover:bg-emerald-600 transition-colors group"
            >
              <Download className="w-8 h-8 mb-2 group-hover:animate-bounce" />
              <span class="text-xs font-bold">Get it now</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { trackEvent, trackSectionVisibility } from '@/lib/analytics'

  trackSectionVisibility('#how-it-works', 'how_it_works')

  document
    .querySelector('#how-it-works-download')
    ?.addEventListener('click', () => {
      trackEvent('download_start', {
        platform: 'android',
        location: 'how_it_works',
      })
    })
</script>
