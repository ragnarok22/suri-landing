---
import { Image } from 'astro:assets'
import { Download as DownloadIcon } from 'lucide-react'
---

<section
  id="download"
  class="py-24 bg-gradient-to-br from-slate-50 to-emerald-50/30 relative overflow-hidden"
>
  <!-- Background decoration -->
  <div
    class="absolute top-0 right-0 w-96 h-96 bg-emerald-200/20 rounded-full blur-3xl"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-96 h-96 bg-yellow-200/20 rounded-full blur-3xl"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-100 text-emerald-700 rounded-full text-sm font-semibold mb-6 border border-emerald-200"
      >
        <DownloadIcon className="w-4 h-4" />
        <span>Ready to get started?</span>
      </div>

      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Download Suri Now
      </h2>
      <p class="text-lg text-slate-600 mb-12 max-w-2xl mx-auto">
        Start managing your mobile credit and data plans with ease. Download
        Suri today and stay connected.
      </p>

      <div class="flex flex-col md:flex-row items-center justify-center gap-6">
        <a
          href="https://github.com/ragnarok22/suri-landing/releases/download/v0.3.2-1/v0.3.2.1.apk"
          id="download-apk"
          class="transition-transform hover:scale-105 hover:drop-shadow-lg"
        >
          <Image
            src="/apk-badge.svg"
            alt="Download Android APK"
            width={180}
            height={60}
          />
        </a>

        <a
          href="#"
          class="relative opacity-50 transition-opacity hover:opacity-60"
        >
          <Image
            src="/google-play-badge.png"
            alt="Google Play - Coming Soon"
            width={180}
            height={60}
          />
          <span
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-slate-900/80 text-white text-xs font-bold px-3 py-1 rounded-full"
          >
            Coming Soon
          </span>
        </a>

        <a
          href="https://apps.apple.com/app/suri-app/id6736572891"
          id="download-apple"
          class="transition-transform hover:scale-105 hover:drop-shadow-lg"
        >
          <Image
            src="/app-store-badge.svg"
            alt="Download on App Store"
            width={180}
            height={60}
          />
        </a>
      </div>

      <div
        class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 text-sm text-slate-500"
      >
        <span class="flex items-center gap-2">
          <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
          No account required
        </span>
        <span class="flex items-center gap-2">
          <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
          100% secure
        </span>
        <span class="flex items-center gap-2">
          <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
          Always free
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  import { track } from '@vercel/analytics'

  const downloadBtn = document.querySelector('a#download-apk')
  const downloadAppleBtn = document.querySelector('a#download-apple')

  downloadBtn?.addEventListener('click', () => {
    track('click_download_apk', {
      location: 'download',
    })
    window.posthog.capture('click_download_apk', {
      location: 'download',
    })
  })
  downloadAppleBtn?.addEventListener('click', () => {
    track('click_download_apple', {
      location: 'download',
    })
    window.posthog.capture('click_download_apple', {
      location: 'download',
    })
  })
</script>
