---
const screenshots = [
  {
    src: '/screenshot1.png',
    darkSrc: '/screenshot1-dark.png',
    alt: 'Suri app home screen showing balance check and mobile credit top-up options for Telesur',
  },
  {
    src: '/screenshot2.png',
    darkSrc: '/screenshot2-dark.png',
    alt: 'Suri app data plans interface displaying available Telesur prepaid data packages',
  },
  {
    src: '/screenshot3.png',
    darkSrc: '/screenshot3-dark.png',
    alt: 'Suri app payment confirmation screen for mobile credit and data plan activation',
  },
  {
    src: '/screenshot4.png',
    darkSrc: '/screenshot4-dark.png',
    alt: 'Suri app usage overview screen showing data consumption and credit history',
  },
]
---

<section
  id="screenshots"
  class="w-full flex justify-center py-12 md:py-24 lg:py-32 bg-slate-100 dark:bg-slate-800"
>
  <div class="container px-4 md:px-6">
    <h2
      class="text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl text-center mb-8 dark:text-slate-100 text-balance"
    >
      App Screenshots
    </h2>
    <div
      class="flex justify-start md:justify-center gap-4 lg:gap-10 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 px-4 md:px-0 -mx-4 md:mx-0"
    >
      {
        screenshots.map((s) => (
          <picture class="shrink-0 snap-center">
            <source
              srcset={s.darkSrc}
              media="(prefers-color-scheme: dark)"
              width="200"
              height="400"
            />
            <img
              src={s.src}
              alt={s.alt}
              width="200"
              height="400"
              loading="lazy"
              class="rounded-lg object-cover"
            />
          </picture>
        ))
      }
    </div>
    <p
      class="text-center text-sm text-slate-400 dark:text-slate-500 mt-4 md:hidden"
    >
      Swipe to see more
    </p>
  </div>
</section>

<script>
  import { trackSectionVisibility } from '@/lib/analytics'

  trackSectionVisibility('#screenshots', 'screenshots')
</script>
