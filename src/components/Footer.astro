<footer class="bg-slate-50 py-12 border-t border-slate-200">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2">
        <div
          class="w-8 h-8 bg-emerald-600 rounded-lg flex items-center justify-center text-white font-bold text-sm"
        >
          S
        </div>
        <span class="text-xl font-bold text-slate-900">Suri</span>
      </div>

      <div
        class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-sm text-slate-500 text-center sm:text-left"
      >
        <a href="/privacy" class="hover:text-emerald-600">Privacy Policy</a>
        <a href="/terms" class="hover:text-emerald-600">Terms of Service</a>
      </div>

      <div class="text-sm text-slate-400">
        © {currentYear} Suri App. All rights reserved.
      </div>
    </div>
  </div>
