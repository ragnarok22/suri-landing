---
import {
  Download,
  ChevronRight,
  Check,
  Wifi,
  CreditCard,
  Zap,
  Globe,
  Star,
} from 'lucide-react'
---

<header class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <!-- Abstract Background Blobs -->
  <div
    class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[800px] h-[800px] bg-emerald-100/40 rounded-full blur-3xl opacity-50 -z-10 animate-pulse-slow"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[600px] h-[600px] bg-yellow-100/40 rounded-full blur-3xl opacity-50 -z-10"
  >
  </div>

  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <!-- Text Content -->
      <div class="lg:w-1/2 space-y-8 text-center lg:text-left">
        <div
          class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-700 rounded-full text-sm font-semibold mb-2 border border-emerald-100"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
            ></span>
          </span>
          The #1 Mobile Manager in Suriname
        </div>

        <h1
          class="text-5xl lg:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.1]"
        >
          Master your <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-green-500"
          >
            Mobile Life
          </span>
        </h1>

        <p
          class="text-lg text-slate-600 max-w-2xl mx-auto lg:mx-0 leading-relaxed"
        >
          Check your balance, top up instantly, and manage data plans with the
          app built for Suriname. Fast, secure, and easy.
        </p>

        <div
          class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4"
        >
          <a
            href="#download"
            id="hero_download"
            class="w-full sm:w-auto px-8 py-4 bg-slate-900 text-white rounded-xl font-bold flex items-center justify-center gap-3 hover:bg-emerald-700 transition-all hover:shadow-xl hover:shadow-emerald-900/10 hover:-translate-y-1 group"
          >
            <Download className="w-5 h-5 group-hover:animate-bounce" />
            <span>Download APK</span>
          </a>
          <a
            href="#features"
            class="w-full sm:w-auto px-8 py-4 bg-white text-slate-700 border border-slate-200 rounded-xl font-bold flex items-center justify-center gap-3 hover:bg-slate-50 transition-all hover:border-slate-300"
          >
            <span>View Features</span>
            <ChevronRight className="w-4 h-4" />
          </a>
        </div>

        <div
          class="pt-4 flex items-center justify-center lg:justify-start gap-6 text-slate-400 text-sm font-medium"
        >
          <span class="flex items-center gap-2"
            ><Check className="w-4 h-4 text-emerald-500" /> Supports Telesur</span
          >
          <span class="flex items-center gap-2"
            ><Check className="w-4 h-4 text-emerald-500" /> Data Management</span
          >
        </div>
      </div>

      <!-- Hero Visual / Interactive Phone -->
      <div class="lg:w-1/2 flex justify-center relative">
        <!-- Decorative elements behind phone -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[650px] bg-gradient-to-tr from-emerald-500/20 to-yellow-400/20 rounded-[3rem] -rotate-6 blur-xl"
        >
        </div>

        <!-- CSS Phone Mockup -->
        <div
          class="relative w-[300px] h-[600px] bg-slate-900 rounded-[3rem] border-8 border-slate-900 shadow-2xl overflow-hidden animate-float"
        >
          <!-- Dynamic Island / Notch -->
          <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-slate-900 rounded-b-2xl z-20"
          >
          </div>

          <!-- Screen Content -->
          <div class="w-full h-full bg-slate-50 relative flex flex-col">
            <!-- Status Bar -->
            <div
              class="h-10 w-full flex justify-between items-center px-6 pt-2 text-[10px] font-bold text-slate-800"
            >
              <span>9:41</span>
              <div class="flex gap-1">
                <Wifi className="w-3 h-3" />
                <div
                  class="w-4 h-2.5 bg-slate-800 rounded-[2px] relative before:absolute before:w-[2px] before:h-1 before:bg-slate-800 before:-right-[3px] before:top-[3px]"
                >
                </div>
              </div>
            </div>

            <!-- App Header -->
            <div class="px-6 py-4">
              <div class="flex justify-between items-center mb-6">
                <div>
                  <p class="text-slate-400 text-xs font-medium">Suri Mobile</p>
                  <h3 class="text-slate-900 font-bold text-lg">Hello, Jason</h3>
                </div>
                <div
                  class="w-10 h-10 bg-emerald-100 rounded-full overflow-hidden border-2 border-white shadow-sm flex items-center justify-center"
                >
                  <span class="font-bold text-emerald-700">JS</span>
                </div>
              </div>

              <!-- Balance Card -->
              <div
                class="w-full bg-gradient-to-br from-emerald-500 to-green-600 rounded-2xl p-5 text-white shadow-lg shadow-emerald-500/30 mb-6 relative overflow-hidden group cursor-pointer transition-transform hover:scale-[1.02]"
              >
                <!-- Abstract Shine -->
                <div
                  class="absolute -top-10 -right-10 w-32 h-32 bg-yellow-400/20 rounded-full blur-2xl"
                >
                </div>
                <div
                  class="absolute bottom-0 left-0 w-24 h-24 bg-white/10 rounded-full -translate-x-1/2 translate-y-1/2 blur-xl"
                >
                </div>

                <p
                  class="text-emerald-50 text-xs font-medium mb-1 flex items-center justify-between"
                >
                  <span>Current Balance</span>
                  <Star className="w-3 h-3 text-yellow-300 fill-yellow-300" />
                </p>
                <h2 class="text-3xl font-bold mb-4">SRD 145.50</h2>
                <div
                  class="flex items-center gap-3 text-xs font-medium bg-black/10 w-fit px-3 py-1.5 rounded-lg backdrop-blur-sm border border-white/10"
                >
                  <div class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse">
                  </div>
                  Valid until Dec 31
                </div>
              </div>

              <!-- Quick Actions -->
              <div class="grid grid-cols-4 gap-2 mb-8">
                <div class="flex flex-col items-center gap-2">
                  <div
                    class="w-12 h-12 rounded-xl flex items-center justify-center bg-emerald-100 text-emerald-700 shadow-sm transition-transform active:scale-95 cursor-pointer"
                  >
                    <CreditCard className="w-5 h-5" />
                  </div>
                  <span class="text-[10px] font-semibold text-slate-500"
                    >Top Up</span
                  >
                </div>
                <div class="flex flex-col items-center gap-2">
                  <div
                    class="w-12 h-12 rounded-xl flex items-center justify-center bg-blue-100 text-blue-600 shadow-sm transition-transform active:scale-95 cursor-pointer"
                  >
                    <Wifi className="w-5 h-5" />
                  </div>
                  <span class="text-[10px] font-semibold text-slate-500"
                    >Data</span
                  >
                </div>
                <div class="flex flex-col items-center gap-2">
                  <div
                    class="w-12 h-12 rounded-xl flex items-center justify-center bg-orange-100 text-orange-600 shadow-sm transition-transform active:scale-95 cursor-pointer"
                  >
                    <Zap className="w-5 h-5" />
                  </div>
                  <span class="text-[10px] font-semibold text-slate-500"
                    >History</span
                  >
                </div>
                <div class="flex flex-col items-center gap-2">
                  <div
                    class="w-12 h-12 rounded-xl flex items-center justify-center bg-purple-100 text-purple-600 shadow-sm transition-transform active:scale-95 cursor-pointer"
                  >
                    <Globe className="w-5 h-5" />
                  </div>
                  <span class="text-[10px] font-semibold text-slate-500"
                    >Roaming</span
                  >
                </div>
              </div>

              <!-- Data Usage -->
              <div
                class="bg-white rounded-2xl p-4 shadow-sm border border-slate-100"
              >
                <div class="flex justify-between items-end mb-2">
                  <span class="text-xs font-bold text-slate-700"
                    >Data Usage</span
                  >
                  <span class="text-[10px] font-semibold text-emerald-600"
                    >Buy More</span
                  >
                </div>
                <div
                  class="w-full bg-slate-100 h-2 rounded-full overflow-hidden mb-2"
                >
                  <div class="h-full bg-emerald-500 w-[65%] rounded-full"></div>
                </div>
                <div
                  class="flex justify-between text-[10px] text-slate-400 font-medium"
                >
                  <span>3.2 GB used</span>
                  <span>5.0 GB total</span>
                </div>
              </div>
            </div>

            <!-- Bottom Nav Mockup -->
            <div
              class="mt-auto bg-white border-t border-slate-100 px-6 py-4 flex justify-between items-center text-slate-300"
            >
              <div class="flex flex-col items-center gap-1 text-emerald-600">
                <div
                  class="w-5 h-5 bg-emerald-600/10 rounded-md flex items-center justify-center"
                >
                  <div class="w-2 h-2 bg-emerald-600 rounded-sm"></div>
                </div>
              </div>
              <div
                class="w-5 h-5 bg-slate-100 rounded-md hover:bg-slate-200 transition-colors"
              >
              </div>
              <div
                class="w-5 h-5 bg-slate-100 rounded-md hover:bg-slate-200 transition-colors"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { track } from '@vercel/analytics'

  const downloadBtn = document.querySelector('#hero_download')

  downloadBtn?.addEventListener('click', () => {
    track('click_download', {
      location: 'hero',
    })
    window.posthog.capture('click_download', {
      location: 'hero',
    })
  })
</script>
